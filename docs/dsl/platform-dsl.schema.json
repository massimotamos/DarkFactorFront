{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darkfactor.local/schema/platform-dsl-3.0.0.json",
  "title": "DarkFactor Business-To-System Canonical DSL",
  "type": "object",
  "required": [
    "metadata",
    "versioning",
    "project",
    "initiative",
    "businessContext",
    "backlog",
    "domainModel",
    "capabilityModel",
    "serviceDesign",
    "workflowModel",
    "nonFunctionalRequirements",
    "constraints",
    "assumptions",
    "risks",
    "architectureInputs",
    "deployableSolutionInputs",
    "traceability",
    "validation"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["schemaId", "schemaVersion", "documentKind", "source"],
      "properties": {
        "schemaId": { "const": "darkfactor.platform.dsl" },
        "schemaVersion": { "const": "3.0.0" },
        "documentKind": { "const": "business-to-system-canonical-specification" },
        "source": { "type": "string" }
      },
      "additionalProperties": false
    },
    "versioning": {
      "type": "object",
      "required": ["documentVersion", "createdAt", "updatedAt", "migrationState", "changeSummary"],
      "properties": {
        "documentVersion": { "type": "integer", "minimum": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "migrationState": { "enum": ["native", "requires-upgrade", "upgrade-in-progress"] },
        "changeSummary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "backlog": {
      "type": "object",
      "required": ["epics", "userStories", "acceptanceCriteria", "businessRules"],
      "properties": {
        "epics": { "type": "array" },
        "userStories": { "type": "array" },
        "acceptanceCriteria": { "type": "array" },
        "businessRules": { "type": "array" }
      },
      "additionalProperties": false
    },
    "domainModel": {
      "type": "object",
      "required": ["actors", "domainEntities", "aggregateGroups"],
      "properties": {
        "actors": { "type": "array" },
        "domainEntities": { "type": "array" },
        "aggregateGroups": { "type": "array" }
      },
      "additionalProperties": false
    },
    "serviceDesign": {
      "type": "object",
      "required": ["serviceCandidates", "responsibilities", "interfaces", "events"],
      "properties": {
        "serviceCandidates": { "type": "array" },
        "responsibilities": { "type": "array" },
        "interfaces": { "type": "array" },
        "events": { "type": "array" }
      },
      "additionalProperties": false
    },
    "workflowModel": {
      "type": "object",
      "required": ["semanticNodes", "visualNodes", "semanticConnections", "visualConnections"],
      "properties": {
        "semanticNodes": { "type": "array" },
        "visualNodes": { "type": "array" },
        "semanticConnections": { "type": "array" },
        "visualConnections": { "type": "array" }
      },
      "additionalProperties": true
    },
    "traceability": {
      "type": "object",
      "required": ["links"],
      "properties": {
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "sourceRef", "targetRef", "relationshipType", "rationale", "confidence"],
            "properties": {
              "id": { "type": "string" },
              "sourceRef": { "type": "string" },
              "targetRef": { "type": "string" },
              "relationshipType": {
                "enum": [
                  "initiative_to_epic",
                  "epic_to_userStory",
                  "userStory_to_acceptanceCriterion",
                  "userStory_to_businessRule",
                  "userStory_to_actor",
                  "userStory_to_domainEntity",
                  "userStory_to_workflowStep",
                  "workflowStep_to_capability",
                  "capability_to_serviceCandidate",
                  "nfr_to_serviceCandidate",
                  "nfr_to_architectureConcern",
                  "risk_to_affectedElement"
                ]
              },
              "rationale": { "type": "string" },
              "confidence": { "enum": ["low", "medium", "high"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["structural", "semantic", "traceability", "completeness", "evolution"],
      "properties": {
        "structural": { "type": "array" },
        "semantic": { "type": "array" },
        "traceability": { "type": "array" },
        "completeness": { "type": "array" },
        "evolution": { "type": "array" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
